<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".samecurrency">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:padding="15dp">

        <RelativeLayout
            android:id="@+id/rel1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/blackabstract"
            android:layout_alignParentTop="true"
            android:layout_marginTop="10dp"

            >
            <TextView
                android:id="@+id/send"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You Send"
                android:textSize="15sp"
                android:textColor="@color/gray1"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="10dp"

                >

            </TextView>
            <TextView
                android:id="@+id/avail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toLeftOf="@id/availamount"
                android:text="Available"
                android:textColor="@color/gray1"
                android:textStyle="bold"
                android:textSize="15sp"
                android:gravity="end"
                android:layout_marginTop="10dp"
                android:layout_marginRight="10dp">

            </TextView>
            <TextView
                android:id="@+id/availamount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="0.0$"
                android:textColor="@color/gray1"
                android:textStyle="bold"
                android:textSize="15sp"
                android:gravity="end"
                android:layout_marginTop="10dp"
                android:layout_marginRight="15dp">

            </TextView>

            <Spinner
                android:id="@+id/csend"
                android:layout_width="90dp"
                android:layout_height="85dp"
                android:entries="@array/SpinnerEntries"
                android:spinnerMode="dialog"
                android:background="@drawable/spinner_background"
                android:backgroundTint="@color/white"
                android:layout_marginTop="5dp"
                android:layout_toRightOf="@id/usic"
                android:layout_below="@id/send"
                android:layout_marginLeft="5dp"

                >

            </Spinner>
            <ImageView
                android:id="@+id/usic"
                android:layout_width="48dp"
                android:layout_height="55dp"
                android:src="@drawable/icus"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="20dp"
                android:layout_below="@id/send"
                >

            </ImageView>
            <EditText
                android:id="@+id/sendamount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_toRightOf="@id/csend"
                android:hint="Amount"
                android:textColorHint="@color/gray1"
                android:textSize="25sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_below="@id/send"
                android:layout_marginTop="28dp"
                android:background="@color/Tranparent"
                android:layout_marginRight="15dp"
                android:inputType="numberDecimal"
                android:gravity="end">

            </EditText>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/sendamount"
                android:layout_alignParentEnd="true"
                android:text="MAX"
                android:textSize="15sp"
                android:textColor="@color/Violet"
                android:textStyle="bold"
                android:layout_marginRight="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="10dp">

            </TextView>


        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/rel2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/rel1"
            android:background="@drawable/stroke"
            android:layout_marginTop="20dp"
            >
            <TextView
                android:id="@+id/paywith"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pay with"
                android:textSize="15sp"
                android:textColor="@color/gray1"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="10dp"

                >

            </TextView>
            <Spinner
                android:id="@+id/pmethod"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:entries="@array/SpinnerEntries3"
                android:spinnerMode="dialog"
                android:background="@drawable/spinner_background"
                android:backgroundTint="@color/Violet"
                android:layout_marginTop="5dp"
                android:layout_toRightOf="@id/methods"
                android:layout_below="@id/paywith"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="20dp"

                >

            </Spinner>
            <ImageView
                android:id="@+id/methods"
                android:layout_width="48dp"
                android:layout_height="55dp"
                android:layout_below="@id/paywith"
                android:src="@drawable/bank"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="20dp"
                >

            </ImageView>






        </RelativeLayout>
        <Button
            android:id="@+id/next2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next"
            android:layout_below="@id/rel2"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_centerHorizontal="true"
            android:backgroundTint="@color/Violet"
            android:padding="10dp"
            android:textColor="@color/white"
            android:layout_marginTop="100dp"
            >

        </Button>








    </RelativeLayout>




</FrameLayout>