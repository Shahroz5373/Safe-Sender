<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TwoFactor"
    android:background="@color/black">

    <RelativeLayout
        android:layout_margin="10dp"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/back"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"/>
        <TextView
            android:id="@+id/text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/back"
            android:text="Two Factor Authentication"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_alignParentTop="true"
            android:gravity="center"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="15dp"/>

        <!-- 2FA Icon -->
        <ImageView
            android:id="@+id/fa_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/text"
            android:src="@drawable/fa_icon"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="15dp"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <!-- Phone Number Input -->
        <EditText
            android:id="@+id/phone_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/fa_icon"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:hint="Enter Phone Number"
            android:inputType="phone"
            android:textColor="@color/white"
            android:textColorHint="@color/gray"
            android:background="@drawable/stroke"
            android:padding="12dp" />

        <!-- Send Code Button -->
        <Button
            android:id="@+id/send_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/phone_number"
            android:layout_marginTop="10dp"
            android:layout_centerHorizontal="true"
            android:text="Send Code"
            android:padding="10dp"
            android:textColor="@color/white"
            android:backgroundTint="@color/Violet" />

        <!-- Code Input Field -->
        <EditText
            android:id="@+id/verification_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/send_code"
            android:layout_marginTop="20dp"
            android:hint="Enter Verification Code"
            android:inputType="number"
            android:textColor="@color/white"
            android:textColorHint="@color/gray"
            android:background="@drawable/stroke"
            android:padding="12dp" />

        <!-- Save Button -->
        <Button
            android:id="@+id/save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/verification_code"
            android:layout_marginTop="40dp"
            android:text="Save"
            android:textSize="16sp"
            android:padding="8dp"
            android:textColor="@color/white"
            android:backgroundTint="@color/Violet" />
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>