<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".recipient"
    android:background="@color/black">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="15dp"
        android:orientation="vertical"
        android:background="@color/black"
        android:layout_margin="15dp"
        >
        <ImageView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/back"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"/>
        <TextView
            android:id="@+id/text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/back"
            android:text="Recipient Details"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_alignParentTop="true"
            android:gravity="center"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="20dp"/>


        <ScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text"
            >
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/usrName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="Recipients's Full Name"
                    android:textSize="20sp"
                    android:layout_marginBottom="15dp"
                    />
                <EditText
                    android:id="@+id/Name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/usrName"
                    android:inputType="text"
                    android:hint="Enter full name"
                    android:textColorHint="@color/gray"
                    android:background="@drawable/stroke"
                    android:padding="15dp"
                    android:layout_marginBottom="15dp"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:layout_below="@+id/Name"
                    android:text="Recipients's Phone Number"
                    android:textSize="20sp"
                    android:layout_marginBottom="15dp"
                    />

                <EditText
                    android:id="@+id/phoneNo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/phone"
                    android:hint="Enter phone number"
                    android:inputType="phone"
                    android:textColorHint="@color/gray"
                    android:background="@drawable/stroke"
                    android:padding="15dp"
                    android:layout_marginBottom="15dp"
                    android:textColor="@color/white"/>
                <TextView
                    android:id="@+id/email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/phoneNo"
                    android:text="Recipient's Email"
                    android:textColor="@color/white"
                    android:textSize="25sp"
                    android:layout_marginBottom="15dp"
                    />

                <EditText
                    android:id="@+id/mail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/email"
                    android:padding="15dp"
                    android:hint="Enter email"
                    android:textColorHint="@color/gray"
                    android:background="@drawable/stroke"
                    android:textColor="@color/white"
                    android:layout_marginBottom="15dp"
                    />
                <TextView
                    android:id="@+id/bdetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bank Details"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_below="@id/mail"
                    android:layout_marginBottom="15dp"/>
                <TextView
                    android:id="@+id/country"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/bdetails"
                    android:textColor="@color/white"
                    android:text="Country"
                    android:textSize="25sp"
                    android:layout_marginBottom="15dp"
                    />

                <AutoCompleteTextView
                    android:id="@+id/Country"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/stroke"
                    android:layout_below="@id/country"
                    android:padding="15dp"
                    android:hint="Enter country"
                    android:drawableEnd="@drawable/dropdown"
                    android:inputType="text"
                    android:textColor="@color/white"
                    android:textColorHint="@color/gray"
                    android:layout_marginBottom="15dp"/>



                <TextView
                    android:id="@+id/address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:layout_below="@+id/Country"
                    android:text="Bank Name"
                    android:textSize="25sp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginTop="15dp"/>

                <EditText
                    android:id="@+id/Address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/address"
                    android:hint="Enter Bank name"
                    android:inputType="text"
                    android:textColorHint="@color/gray"
                    android:background="@drawable/stroke"
                    android:padding="15dp"
                    android:layout_marginBottom="15dp"
                    android:textColor="@color/white"/>
                <TextView
                    android:id="@+id/accountnoh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:layout_below="@id/Address"
                    android:text="Recipient's Account Number"
                    android:textSize="20sp"
                    android:layout_marginBottom="15dp"
                    />
                <EditText
                    android:id="@+id/accountno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/accountnoh"
                    android:inputType="text"
                    android:hint="Enter Account Number"
                    android:textColorHint="@color/gray"
                    android:background="@drawable/stroke"
                    android:padding="15dp"
                    android:layout_marginBottom="15dp"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/swift"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:layout_below="@+id/accountno"
                    android:text="Swift/BIC Code"
                    android:textSize="25sp"
                    android:layout_marginBottom="15dp" />


                <EditText
                    android:id="@+id/swiftcode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/swift"
                    android:hint="Enter password"
                    android:inputType="textPassword"
                    android:textColorHint="@color/gray"
                    android:background="@drawable/stroke"
                    android:textColor="@color/white"
                    android:padding="15dp"
                    android:layout_marginBottom="15dp"/>
                <RelativeLayout
                    android:id="@+id/rel3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/swiftcode"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="15dp"
                    >
                    <TextView
                        android:id="@+id/bankfee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bank Fee"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:layout_marginLeft="10dp">

                    </TextView>
                    <TextView
                        android:id="@+id/bankfee2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toRightOf="@id/swapfee"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:text="0.0$"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginRight="10dp">

                    </TextView>
                    <TextView
                        android:id="@+id/ourfee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Our Fee"
                        android:layout_below="@id/bankfee"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:layout_marginLeft="10dp">

                    </TextView>
                    <TextView
                        android:id="@+id/ourfee2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toRightOf="@id/swapfee"
                        android:layout_below="@id/bankfee2"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:text="0.0$"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginRight="10dp">

                    </TextView>
                    <TextView
                        android:id="@+id/totalfee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Fee"
                        android:layout_below="@id/ourfee"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:layout_marginLeft="10dp">

                    </TextView>
                    <TextView
                        android:id="@+id/totalfee2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toRightOf="@id/swapfee"
                        android:layout_below="@id/ourfee2"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:text="0.0$"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginRight="10dp">

                    </TextView>
                    <TextView
                        android:id="@+id/total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recipient will get"
                        android:layout_below="@id/totalfee"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:layout_marginLeft="10dp">

                    </TextView>
                    <TextView
                        android:id="@+id/total2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toRightOf="@id/total"
                        android:layout_below="@id/totalfee2"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:text="0.0€"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginRight="10dp">

                    </TextView>

                </RelativeLayout>
                <Button
                    android:id="@+id/registers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/rel3"
                    android:text="Pay"
                    android:padding="15dp"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="15dp"
                    android:layout_marginTop="15dp"
                    android:backgroundTint="@color/NeonGreen"/>









            </RelativeLayout>
        </ScrollView>
    </RelativeLayout>



</androidx.constraintlayout.widget.ConstraintLayout>